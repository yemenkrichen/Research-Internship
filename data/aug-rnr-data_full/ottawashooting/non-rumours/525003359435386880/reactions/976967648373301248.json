{"contributors": null, "coordinates": null, "created_at": "Thu Mar 22 23:43:33 +0000 2018", "display_text_range": [0, 275], "entities": {"hashtags": [{"indices": [192, 209], "text": "ActuallyAutistic"}], "symbols": [], "urls": [], "user_mentions": []}, "favorite_count": 122, "favorited": false, "full_text": "No. I'm Autistic.\n\nI don't want to be called \"with autism.\" It isn't even remotely accurate. I don't carry autism around in a satchel, FFS. I don't live \"with\" a roommate named Autism. \n\nI am #ActuallyAutistic. \n\nNon-autistics should stop with PFL. Stop. You aren't helping \ud83d\ude21", "geo": null, "id": 976967648373301200, "id_str": "976967648373301248", "in_reply_to_screen_name": null, "in_reply_to_status_id": null, "in_reply_to_status_id_str": null, "in_reply_to_user_id": null, "in_reply_to_user_id_str": null, "is_quote_status": false, "lang": "en", "place": null, "retweet_count": 34, "retweeted": false, "source": "<a href=\"http://twitter.com/download/iphone\" rel=\"nofollow\">Twitter for iPhone</a>", "truncated": false, "user": {"contributors_enabled": false, "created_at": "Mon Aug 29 20:02:36 +0000 2016", "default_profile": false, "default_profile_image": false, "description": "They/she, 35yo faceblind late-dx #ActuallyAutistic blogger/writer, #AutisticParent, musician. Current interests: autism, history, music, sociology, education.", "entities": {"description": {"urls": []}, "url": {"urls": [{"display_url": "mamautistic.wordpress.com", "expanded_url": "http://mamautistic.wordpress.com", "indices": [0, 23], "url": "https://t.co/s7LchKkWQ0"}]}}, "favourites_count": 58123, "follow_request_sent": false, "followers_count": 1719, "following": false, "friends_count": 791, "geo_enabled": false, "has_extended_profile": false, "id": 770350960669495300, "id_str": "770350960669495296", "is_translation_enabled": false, "is_translator": false, "lang": "en", "listed_count": 29, "location": "USA", "name": "Aria Sky Awareness Month", "notifications": false, "