#The following function cleans text by removing white spaces and URLs and ensures converting unique charachters into standard formats.
def normalize(text):
    text = unicodedata.normalize('NFKC', text)
    text = text.lower()
    text = re.sub(r'http\S+', '', text)
    text = text.replace('\u201c', '"').replace('\u201d', '"')
    text = text.replace('\u2018', "'").replace('\u2019', "'")
    text = re.sub(r'\s+', ' ', text).strip()
    return text

