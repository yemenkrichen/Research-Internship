doubtful_lower = {t.lower() for t in doubtful}
immune_lower = {t.lower() for t in immune}
irrelevant_lower = {t.lower() for t in irrelevant}
doubtful_norm = {normalize(t) for t in doubtful}
immune_norm = {normalize(t) for t in immune}
irrelevant_norm = {normalize(t) for t in irrelevant}
vader = SentimentIntensityAnalyzer()


#classify the activity into its adequate compartment from my SDPNRI model
def classify(text):

    txt = text.lower()
    if normalize(txt) in doubtful_norm:
        return "D", txt
    if normalize(txt) in immune_norm:
        return "I", txt

    try:
        detected = detect(txt) #detect the language of the text
    except LangDetectException:
        detected = "unknown"

    if detected == "en":
        translated = txt
    else:
        translated = GoogleTranslator(source="auto", target="en").translate(txt)#if text not in English translate

    if normalize(txt) in irrelevant_norm:
        return "skip", translated

    score = vader.polarity_scores(translated)["compound"]
    if score <= -0.5:
        return "N", translated
    return "P", translated


def parse_time(act):
    return datetime.strptime(act["created_at"], date_format)


def main():
    with open("boston_users_database.json", "r", encoding="utf-8") as f:
        users_db = json.load(f)

    # deduplicate the activities that appear twice in the user dataset
    seen_tweet_ids = set()
    user_activities = {} 

    for user, activities in users_db.items():
        deduped = []
        for act in activities:
            tid = act.get("tweet_id")
            if tid is None or tid in seen_tweet_ids:
                continue
            seen_tweet_ids.add(tid)
            deduped.append(act)
        if deduped:
            deduped.sort(key=parse_time)
            user_activities[user] = deduped

    
    all_times = [parse_time(a) for acts in user_activities.values() for a in acts]
    t0 = min(all_times)#gives the earliest activity time according to my dataset
    print(f"Global t0 = {t0}") 

    def global_seconds(act):
        return (parse_time(act) - t0).total_seconds()

    user_transitions = {}
    events = []

    for user, activities in user_activities.items():
        transitions = []
        prev_state = "S" #all users are initialized as suceptibles

        for act in activities:
            text = act.get("text", "")
            t_sec = global_seconds(act)
            state, translated = classify(text)

            if state == "skip":
                continue
            if prev_state == "I":
                state = "I"
            transitions.append({
                "thread_id": act.get("thread_id"),
                "tweet_id": act.get("tweet_id"),
                "action_type": act.get("type"),
                "timestamp": act.get("created_at"),
                "seconds_since_global_t0": t_sec,
                "sentiment_score": vader.polarity_scores(translated)["compound"] if translated else 0.0,
                "state": state,
                "transition": f"{prev_state} -> {state}",
                "text": text,
                "translated": translated if text.lower() != translated else None
            })
            events.append({"time": t_sec, "user": user, "to_state": state})
            prev_state = state

        user_transitions[user] = transitions

    observation_end = max(e["time"] for e in events)

    last_activity_time = {}
    for e in events:
        last_activity_time[e["user"]] = max(last_activity_time.get(e["user"], e["time"]), e["time"])

    final_state = {
    user: transitions[-1]["state"] 
    for user, transitions in user_transitions.items() if transitions
    }

    n_restrained = 0
    for user, last_t in last_activity_time.items():
        if final_state.get(user) == "I":
            continue
        restrained_time = last_t + restrained_after
        if restrained_time <= observation_end:
            events.append({"time": restrained_time, "user": user, "to_state": "R"})
            n_restrained += 1

    n_immune = sum(1 for s in final_state.values() if s == "I")
    print(f"{n_restrained} of {len(user_activities) - n_immune} non-immune users "
          f"went quiet for >{restrained_after}s before the observation "
          f"({n_immune} immune users)")

    with open("boston_user_transitions.json", "w", encoding="utf-8") as out:
        json.dump(user_transitions, out, indent=4)

    events.sort(key=lambda e: e["time"])

    valid_users = set()
    for user, activities in user_activities.items():
        for act in activities:
            state, _ = classify(act.get("text", ""))
            if state != "skip":
                valid_users.add(user)
                break 

    all_users = list(valid_users)
    current_populations = {"S": len(all_users), "D": 0, "P": 0, "N": 0, "I": 0, "R": 0}
    user_states = {u: "S" for u in all_users}

    population_timeline = []
    for event in events:
        u, new_state = event["user"], event["to_state"]
        old_state = user_states[u]
        if old_state != new_state:
            current_populations[old_state] -= 1
            current_populations[new_state] += 1
            user_states[u] = new_state
            population_timeline.append({"time": event["time"], **current_populations})

    times = [e["time"] for e in population_timeline]
    series = {k: [e[k] for e in population_timeline] for k in ("S", "D", "P", "N", "I", "R")}

    colors = {"S": "#7f8c8d", "D": "#f39c12", "P": "#e74c3c", "N": "#9b59b6","I": "#2ecc71", "R": "#3498db"}
    labels = {
        "S": "S (Susceptible)",
        "D": "D (Doubtful)",
        "P": "P (Positively Infected)",
        "N": "N (Negatively Infected)",
        "I": "I (Immune - Debunkers)",
        "R": f"R (Restrained - quiet >{restrained_after}s)",
    }

    plt.figure(figsize=(12, 6))
    for k in ("S", "D", "P", "N", "I", "R"):
        style = "--" if k == "S" else "-"
        plt.plot(times, series[k], label=labels[k], color=colors[k],linewidth=2, linestyle=style)

    plt.title("SDPNRI Compartment Dynamics Over Time (Boston Bombings)",
              fontsize=14, fontweight="bold")
    plt.xlabel("Seconds Since Global $t_0$", fontsize=12)
    plt.ylabel("Number of Users", fontsize=12)
    plt.xscale("symlog", linthresh=3000)
    plt.grid(True, linestyle=":", alpha=0.6)
    plt.legend(loc="upper right", frameon=True, shadow=True)
    plt.tight_layout()
    plt.xlim(0, 600000)
    plt.savefig("sdpnri_timeline_diagram.png", dpi=300)
    print("Saved timeline plot as 'sdpnri_timeline_diagram.png'")


if __name__ == "__main__":
    main()
